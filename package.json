{
  "name": "agent-evaluation",
  "version": "0.1.0",
  "description": "Kaltura Agent Evaluation Service",
  "author": "Kaltura",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "nest start agent-eval",
    "start:dev": "nest start agent-eval --watch",
    "lint": "eslint --max-warnings=0 'shared/**/*.ts' 'apps/**/*.ts'",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^8.1.1",
    "axios": "^1.17.0",
    "mongoose": "^8.24.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^shared/(.*)$": "<rootDir>/shared/$1"
    },
    "testEnvironment": "node",
    "roots": [
      "<rootDir>",
      "<rootDir>/apps/"
    ]
  },
  "engines": {
    "node": ">=20.0.0 < 24.0.0"
  }
}
